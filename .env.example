# ──────────────────────────────────────────────────────────────
# Mosi-oa-Tunya AI — Environment Variables
# Copy to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Mosi-oa-Tunya AI"
# Demo mode simulates Stellar, mobile money, FX & payments. Set to false in prod.
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Stellar (https://developers.stellar.org)
# Use the testnet horizon while developing.
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PUBLIC_KEY=
STELLAR_SECRET_KEY=
STELLAR_DISTRIBUTION_SECRET=
# Anchored stablecoin asset used for settlement (e.g. USDC)
STELLAR_SETTLEMENT_ASSET_CODE=USDC
STELLAR_SETTLEMENT_ASSET_ISSUER=

# Payment providers (server-side secrets only)
FLUTTERWAVE_SECRET_KEY=
PAYCHANGU_SECRET_KEY=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
ZAMTEL_KWACHA_API_KEY=

# Exchange rate provider
EXCHANGE_RATES_API_KEY=
