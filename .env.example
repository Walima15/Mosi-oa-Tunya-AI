# ──────────────────────────────────────────────────────────────
# Mosi-oa-Tunya AI — Environment Variables
# Copy to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Mosi-oa-Tunya AI"
# Demo mode simulates Stellar, mobile money, FX & payments. Set to false in prod.
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Stellar (https://developers.stellar.org)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
# Your existing Testnet public key (G... only — safe for client display)
NEXT_PUBLIC_STELLAR_PUBLIC_KEY=
# Optional server-only duplicate (never use S... secret keys here)
STELLAR_PUBLIC_KEY=
# Server-only secret for signing transactions — NEVER commit or expose to client
STELLAR_SECRET_KEY=
STELLAR_DISTRIBUTION_SECRET=
# AES-256 key used to encrypt user Stellar secret keys at rest (server-only).
STELLAR_ENCRYPTION_KEY=
# Anchored stablecoin asset used for settlement (e.g. USDC)
STELLAR_SETTLEMENT_ASSET_CODE=USDC
STELLAR_SETTLEMENT_ASSET_ISSUER=
# Client-safe Stellar labels (for UI badges)
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SETTLEMENT_ASSET=USDC
# USD/ZMW rate for wallet display estimates
NEXT_PUBLIC_USD_ZMW_RATE=27.62
# Testnet Circle USDC issuer (classic asset) + Soroban SAC contract address
NEXT_PUBLIC_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQVOFLHQ7FQY2W5Q4EYE5Z
USDC_SAC_CONTRACT=

# Soroban smart contracts (https://developers.stellar.org/docs/build/smart-contracts)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_DEPLOYER_SECRET=
# Deployed contract IDs (from `stellar contract deploy`)
NEXT_PUBLIC_FAMILY_WALLET_CONTRACT_ID=
NEXT_PUBLIC_GOAL_VAULT_CONTRACT_ID=
NEXT_PUBLIC_SPLIT_PAYMENT_CONTRACT_ID=
NEXT_PUBLIC_AUTOMATION_CONTRACT_ID=

# Payment providers (server-side secrets only)
FLUTTERWAVE_SECRET_KEY=
PAYCHANGU_SECRET_KEY=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
ZAMTEL_KWACHA_API_KEY=

# Exchange rate provider
EXCHANGE_RATES_API_KEY=
